# ── Banco de Dados ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres123@db:5432/antidesperdicio

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Segurança ───────────────────────────────────────────────────────
SECRET_KEY=mude-esta-chave-em-producao-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── IA (opcional) ───────────────────────────────────────────────────
# Cole sua chave aqui para ativar o AgroBot com LLM real
# Sem chave, o chatbot funciona em modo demo com respostas pré-definidas
OPENAI_API_KEY=

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
